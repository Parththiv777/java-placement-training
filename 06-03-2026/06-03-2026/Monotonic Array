class Solution {
    public boolean isMonotonic(int[] nums) {
        boolean isAsc = true;
        boolean isDec = true;

        for (int i = 0; i < nums.length - 1; i++) {
            if (nums[i] < nums[i + 1]) {
                isDec = false;   // violates decreasing condition
            }
            if (nums[i] > nums[i + 1]) {
                isAsc = false;   // violates increasing condition
            }
        }

        return isAsc || isDec;
    }
}
